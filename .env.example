# Recall API runtime
RECALL_ENV=dev
RECALL_VERSION=0.2.0
RECALL_ENFORCE_HTTPS=false

# Security / auth
JWT_SECRET=change-me-in-production
# Optional comma-separated secret rotation list (first item is active signer)
JWT_SECRETS=change-me-in-production,old-secret-for-validation
RECALL_AUTH_LOCKOUT_THRESHOLD=5
RECALL_AUTH_LOCKOUT_MINUTES=15

# Database / cache / broker
DATABASE_URL=postgresql+psycopg2://recall:recall@localhost:5432/recall
REDIS_URL=redis://localhost:6379/0
RECALL_AUTO_CREATE_SCHEMA=true

# Bootstrap admin (dev-only default usage)
RECALL_BOOTSTRAP_ADMIN_USERNAME=admin
RECALL_BOOTSTRAP_ADMIN_PASSWORD=change-me

# Upload / media pipeline
MEDIA_DIR=/var/lib/recall/media
RECALL_MAX_UPLOAD_BYTES=209715200
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
RECALL_CLAMAV_FAIL_OPEN=false

# Device lifecycle
HEARTBEAT_TIMEOUT=60

# CORS
RECALL_CORS_ORIGINS=http://localhost,http://127.0.0.1
