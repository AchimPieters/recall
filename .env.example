# Recall platform environment example
# Copy to `.env` for local development and adjust values.

# --- Core runtime ---
RECALL_ENV=dev
RECALL_VERSION=0.2.0
RECALL_ENFORCE_HTTPS=false
RECALL_CORS_ORIGINS=http://localhost,http://127.0.0.1
RECALL_AUTO_CREATE_SCHEMA=true

# --- Database / queue ---
DATABASE_URL=postgresql+psycopg2://recall:recall@localhost:5432/recall
REDIS_URL=redis://localhost:6379/0

# --- Auth / security ---
JWT_SECRET=change-me-in-production
# Optional key rotation list; first value becomes active signing key.
JWT_SECRETS=change-me-in-production,old-key-for-verification
RECALL_AUTH_LOCKOUT_THRESHOLD=5
RECALL_AUTH_LOCKOUT_MINUTES=15
RECALL_PASSWORD_MIN_LENGTH=12
RECALL_PASSWORD_REQUIRE_UPPER=true
RECALL_PASSWORD_REQUIRE_LOWER=true
RECALL_PASSWORD_REQUIRE_DIGIT=true
RECALL_PASSWORD_REQUIRE_SYMBOL=true

# Bootstrap admin is only used when no admin exists yet.
RECALL_BOOTSTRAP_ADMIN_USERNAME=admin
RECALL_BOOTSTRAP_ADMIN_PASSWORD=change-me

# --- Device / media ---
MEDIA_DIR=/media
RECALL_MAX_UPLOAD_BYTES=209715200
HEARTBEAT_TIMEOUT=60
RECALL_FFPROBE_BINARY=ffprobe
RECALL_FFPROBE_TIMEOUT_SECONDS=5

# --- Malware scanning ---
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
# Must stay false outside development.
RECALL_CLAMAV_FAIL_OPEN=false
